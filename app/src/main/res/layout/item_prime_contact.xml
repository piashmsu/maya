<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <View
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_prime_badge" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/primeItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/myra_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/primeItemNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/myra_text_secondary"
            android:textSize="12sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/primeItemDelete"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/dialog_cancel"
        android:src="@drawable/ic_close" />
</LinearLayout>
